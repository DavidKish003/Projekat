@model PrezentacionaLogika.ZahtevViewModel

@{
    ViewBag.Title = "Detalji prijave";

    string statusPrijave =
        Convert.ToString(Model.StatusZahteva);

    string klasaStatusa =
        "oznaka-statusa status-nepoznat";

    if (string.Equals(
        statusPrijave,
        "Primljena",
        StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-primljena";
    }
    else if (string.Equals(
        statusPrijave,
        "U razmatranju",
        StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-razmatranje";
    }
    else if (string.Equals(
        statusPrijave,
        "Izabran",
        StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-izabran";
    }
    else if (
        string.Equals(
            statusPrijave,
            "Odbijena",
            StringComparison.OrdinalIgnoreCase)
        ||
        string.Equals(
            statusPrijave,
            "Odbijen",
            StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-odbijena";
    }

    bool korisnikJeAdministrator =
        string.Equals(
            Convert.ToString(Session["Uloga"]),
            "Admin",
            StringComparison.OrdinalIgnoreCase
        )
        ||
        string.Equals(
            Convert.ToString(Session["Uloga"]),
            "Administrator",
            StringComparison.OrdinalIgnoreCase
        );

    string akcijaZaPovratak =
        korisnikJeAdministrator
            ? "Index"
            : "MojePrijave";
}

<style>
    .stranica-detalja {
        max-width: 1050px;
        margin: 35px auto;
        color: #1e293b;
    }

    .zaglavlje-detalja {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 25px;
        margin-bottom: 25px;
        padding: 32px;
        border-radius: 20px;
        background: linear-gradient( 135deg, #0f172a, #1e3a5f );
        color: #ffffff;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.16);
    }

    .mali-naslov {
        margin-bottom: 8px;
        color: rgba(255, 255, 255, 0.72);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .ime-kandidata {
        margin: 0 0 10px;
        font-size: 34px;
        font-weight: 700;
    }

    .naziv-konkursa-zaglavlje {
        margin: 0;
        color: rgba(255, 255, 255, 0.82);
        font-size: 17px;
        line-height: 1.5;
    }

    .oznaka-statusa {
        display: inline-block;
        min-width: 120px;
        padding: 10px 16px;
        border-radius: 30px;
        text-align: center;
        font-size: 14px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-primljena {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-razmatranje {
        background: #fef3c7;
        color: #92400e;
    }

    .status-izabran {
        background: #dcfce7;
        color: #166534;
    }

    .status-odbijena {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-nepoznat {
        background: #e2e8f0;
        color: #475569;
    }

    .mreza-podataka {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
        margin-bottom: 25px;
    }

    .kartica-podataka {
        padding: 25px;
        border: 1px solid #e2e8f0;
        border-radius: 17px;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    }

    .naslov-kartice {
        margin: 0 0 20px;
        padding-bottom: 13px;
        border-bottom: 1px solid #e2e8f0;
        color: #0f172a;
        font-size: 19px;
        font-weight: 700;
    }

    .red-podatka {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        padding: 11px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .red-podatka:last-child {
            border-bottom: none;
        }

    .naziv-podatka {
        color: #64748b;
        font-size: 14px;
        font-weight: 600;
    }

    .vrednost-podatka {
        max-width: 65%;
        color: #1e293b;
        text-align: right;
        font-size: 14px;
        font-weight: 700;
        overflow-wrap: anywhere;
    }

    .uslov-ispunjen {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        background: #dcfce7;
        color: #166534;
        font-weight: 700;
    }

    .uslov-nije-ispunjen {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 700;
    }

    .odeljak-sadrzaja {
        margin-bottom: 25px;
        padding: 25px;
        border: 1px solid #e2e8f0;
        border-radius: 17px;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    }

    .tekst-motivacionog-pisma {
        min-height: 90px;
        padding: 18px;
        border-left: 4px solid #0f766e;
        border-radius: 8px;
        background: #f8fafc;
        color: #334155;
        line-height: 1.75;
        white-space: pre-line;
        overflow-wrap: anywhere;
    }

    .prazan-sadrzaj {
        color: #64748b;
        font-style: italic;
    }

    .spisak-dokumenata {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .stavka-dokumenta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 14px 16px;
        border-bottom: 1px solid #e2e8f0;
    }

        .stavka-dokumenta:last-child {
            border-bottom: none;
        }

    .naziv-dokumenta {
        color: #334155;
        font-weight: 600;
    }

    .dokument-dostavljen {
        padding: 6px 11px;
        border-radius: 20px;
        background: #dcfce7;
        color: #166534;
        font-size: 13px;
        font-weight: 700;
    }

    .dokument-nije-dostavljen {
        padding: 6px 11px;
        border-radius: 20px;
        background: #fee2e2;
        color: #991b1b;
        font-size: 13px;
        font-weight: 700;
    }

    .dugmad-akcije {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 25px;
    }

    .dugme-akcije {
        display: inline-block;
        padding: 11px 20px;
        border: none;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .dugme-akcije:hover {
            text-decoration: none;
            transform: translateY(-2px);
        }

    .dugme-nazad {
        background: #e2e8f0;
        color: #334155;
    }

        .dugme-nazad:hover {
            background: #cbd5e1;
            color: #1e293b;
        }

    .dugme-izmeni {
        background: #2563eb;
        color: #ffffff;
    }

        .dugme-izmeni:hover {
            background: #1d4ed8;
            color: #ffffff;
        }

    .dugme-stampaj {
        background: #0f766e;
        color: #ffffff;
    }

        .dugme-stampaj:hover {
            background: #115e59;
            color: #ffffff;
        }

    .zaglavlje-za-stampu,
    .podnozje-za-stampu {
        display: none;
    }

    @@media (max-width: 768px) {
        .stranica-detalja {
            margin-top: 20px;
        }

        .zaglavlje-detalja {
            flex-direction: column;
            padding: 25px;
        }

        .ime-kandidata {
            font-size: 28px;
        }

        .mreza-podataka {
            grid-template-columns: 1fr;
        }

        .red-podatka {
            flex-direction: column;
            gap: 5px;
        }

        .vrednost-podatka {
            max-width: 100%;
            text-align: left;
        }

        .stavka-dokumenta {
            align-items: flex-start;
            flex-direction: column;
            gap: 8px;
        }

        .dugmad-akcije {
            flex-direction: column;
        }

            .dugmad-akcije .dugme-akcije {
                width: 100%;
                text-align: center;
                box-sizing: border-box;
            }
    }

    @@page {
        size: A4 portrait;
        margin: 12mm;
    }

