            background: #ffffff !important;
            color: #000000 !important;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 10.5pt;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        nav,
        footer,
        header,
        .navbar,
        .dugmad-akcije {
            display: none !important;
        }

        .container,
        .body-content {
            width: 100% !important;
            max-width: none !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .stranica-detalja {
            width: 100% !important;
            max-width: none !important;
            margin: 0 !important;
            padding: 0 !important;
            color: #000000 !important;
        }

        .zaglavlje-za-stampu {
            display: block !important;
            margin-bottom: 7mm;
            padding-bottom: 4mm;
            border-bottom: 2px solid #000000;
        }

        .stampano-zaglavlje-gornji-red {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10mm;
        }

        .stampano-zaglavlje-naslov {
            margin: 0 0 2mm;
            color: #000000;
            font-size: 20pt;
            font-weight: 700;
        }

        .stampano-zaglavlje-opis {
            margin: 0;
            color: #333333;
            font-size: 10pt;
        }

        .stampano-zaglavlje-meta {
            min-width: 58mm;
            border-collapse: collapse;
            font-size: 9.5pt;
        }

            .stampano-zaglavlje-meta td {
                padding: 1.2mm 0 1.2mm 4mm;
                vertical-align: top;
            }

                .stampano-zaglavlje-meta td:first-child {
                    padding-left: 0;
                    color: #555555;
                    font-weight: 600;
                    white-space: nowrap;
                }

                .stampano-zaglavlje-meta td:last-child {
                    color: #000000;
                    font-weight: 700;
                    text-align: right;
                }

        .zaglavlje-detalja {
            display: flex !important;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8mm;
            margin-bottom: 6mm;
            padding: 5mm;
