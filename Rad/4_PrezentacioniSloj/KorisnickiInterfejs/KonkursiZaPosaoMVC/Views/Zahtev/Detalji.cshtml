            color: #000000 !important;
            text-align: right !important;
            font-size: 9.5pt;
            font-weight: 700;
        }

        .uslov-ispunjen,
        .uslov-nije-ispunjen,
        .dokument-dostavljen,
        .dokument-nije-dostavljen {
