            line-height: 1.5;
        }

        .spisak-dokumenata {
            margin: 0;
            padding: 0;
        }

        .stavka-dokumenta {
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            justify-content: space-between;
            gap: 5mm;
            padding: 2.5mm 1mm;
            border-bottom: 1px solid #cccccc;
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .naziv-dokumenta {
            color: #000000 !important;
            font-size: 9.5pt;
        }

        .prazan-sadrzaj {
