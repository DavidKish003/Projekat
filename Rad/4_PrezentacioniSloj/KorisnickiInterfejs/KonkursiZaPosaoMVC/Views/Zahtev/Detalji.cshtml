    }
</style>

<div class="stranica-detalja">

    <div class="zaglavlje-za-stampu">

        <div class="stampano-zaglavlje-gornji-red">

            <div>

                <h1 class="stampano-zaglavlje-naslov">
                    Izveštaj o prijavi kandidata
                </h1>

                <p class="stampano-zaglavlje-opis">
                    Sistem za prijavu kandidata i obradu konkursa za posao
                </p>

            </div>

            <table class="stampano-zaglavlje-meta">

                <tr>
                    <td>Broj prijave:</td>
                    <td>@Model.ZahtevID</td>
                </tr>

                <tr>
                    <td>Datum štampanja:</td>
                    <td>
                        @String.Format(
                                 "{0:dd.MM.yyyy HH:mm}",
                                 DateTime.Now
                             )
                    </td>
                </tr>

                <tr>
                    <td>Status:</td>
                    <td>@statusPrijave</td>
                </tr>

            </table>

        </div>

    </div>

    <div class="zaglavlje-detalja">

        <div>

            <div class="mali-naslov">
                Detalji prijave kandidata
            </div>

            <h1 class="ime-kandidata">
                @Model.ImePrezime
            </h1>

            <p class="naziv-konkursa-zaglavlje">
                Konkurs: @Model.NazivKonkursa
            </p>

        </div>

        <span class="@klasaStatusa">
            @statusPrijave
        </span>

    </div>

    <div class="mreza-podataka">

        <div class="kartica-podataka">

            <h2 class="naslov-kartice">
                Podaci o kandidatu
            </h2>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Ime i prezime
                </span>

                <span class="vrednost-podatka">
                    @Model.ImePrezime
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    E-mail
                </span>

                <span class="vrednost-podatka">
                    @Model.Email
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Telefon
                </span>

                <span class="vrednost-podatka">
                    @Model.KontaktTelefon
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Poslednja završena škola
                </span>

                <span class="vrednost-podatka">

                    @if (string.IsNullOrWhiteSpace(Model.PoslednjaSkola))
                    {
                        <span>Nije uneto</span>
                    }
                    else
                    {
                        @Model.PoslednjaSkola
                    }

                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Mesto škole
                </span>

                <span class="vrednost-podatka">

                    @if (string.IsNullOrWhiteSpace(Model.MestoSkole))
                    {
                        <span>Nije uneto</span>
                    }
                    else
                    {
                        @Model.MestoSkole
                    }

                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Stečeno zanimanje
                </span>

                <span class="vrednost-podatka">

                    @if (string.IsNullOrWhiteSpace(Model.Zanimanje))
                    {
                        <span>Nije uneto</span>
                    }
                    else
                    {
                        @Model.Zanimanje
                    }

                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Stepen obrazovanja
                </span>

                <span class="vrednost-podatka">
                    @Model.StepenObrazovanja
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Godine iskustva
                </span>

                <span class="vrednost-podatka">
                    @Model.GodineIskustva
                </span>

            </div>

        </div>

        <div class="kartica-podataka">

            <h2 class="naslov-kartice">
                Podaci o prijavi
            </h2>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Naziv konkursa
                </span>

                <span class="vrednost-podatka">
                    @Model.NazivKonkursa
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Radno mesto
                </span>

                <span class="vrednost-podatka">

                    @if (string.IsNullOrWhiteSpace(Model.RadnoMesto))
                    {
                        <span>Nije uneto</span>
                    }
                    else
                    {
                        @Model.RadnoMesto
                    }

                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Datum podnošenja
                </span>

                <span class="vrednost-podatka">
                    @String.Format(
                             "{0:dd.MM.yyyy}",
                             Model.DatumPodnosenja
                         )
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Rok konkursa
                </span>

                <span class="vrednost-podatka">
                    @String.Format(
                             "{0:dd.MM.yyyy}",
                             Model.RokKonkursa
                         )
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Status prijave
                </span>

                <span class="vrednost-podatka">
                    @statusPrijave
                </span>

            </div>

            <div class="red-podatka">

                <span class="naziv-podatka">
                    Ispunjava osnovne uslove
                </span>

                <span class="vrednost-podatka">

                    @if (Model.IspunjavaOsnovneUslove)
                    {
                        <span class="uslov-ispunjen">
                            Da
                        </span>
                    }
                    else
                    {
                        <span class="uslov-nije-ispunjen">
                            Ne
                        </span>
                    }

                </span>

            </div>

        </div>

    </div>

    <div class="odeljak-sadrzaja">

        <h2 class="naslov-kartice">
            Motivaciono pismo
        </h2>

        <div class="tekst-motivacionog-pisma">

            @if (string.IsNullOrWhiteSpace(
                Model.MotivacionoPismo))
            {
                <span class="prazan-sadrzaj">
                    Nije uneto motivaciono pismo.
                </span>
            }
            else
            {
                @Model.MotivacionoPismo
            }

        </div>

    </div>

    <div class="odeljak-sadrzaja">

        <h2 class="naslov-kartice">
            Dokumentacija
        </h2>

        @if (Model.Dokumentacija != null &&
             Model.Dokumentacija.Count > 0)
        {
            <ul class="spisak-dokumenata">

                @foreach (var dokument in Model.Dokumentacija)
                {
                    <li class="stavka-dokumenta">

                        <span class="naziv-dokumenta">
                            @dokument.NazivDokumenta
                        </span>

                        @if (dokument.Dostavljen)
                        {
                            <span class="dokument-dostavljen">
                                Dostavljen
                            </span>
                        }
                        else
                        {
                            <span class="dokument-nije-dostavljen">
                                Nije dostavljen
                            </span>
                        }

                    </li>
                }

            </ul>
        }
        else
        {
            <p class="prazan-sadrzaj">
                Nema podataka o dokumentaciji.
            </p>
        }

    </div>

    <div class="podnozje-za-stampu">

        <div class="potpisi-za-stampu">

            <div class="potpis-polje">
                Potpis kandidata
            </div>

            <div class="potpis-polje">
                Potpis ovlašćenog lica
            </div>

        </div>

        <div class="napomena-za-stampu">
            Dokument je generisan iz sistema za prijavu kandidata
            i obradu konkursa za posao. Podaci prikazani u dokumentu
            odgovaraju stanju prijave u trenutku štampanja.
        </div>

    </div>

    <div class="dugmad-akcije">

        <a class="dugme-akcije dugme-nazad"
           href="@Url.Action(
               akcijaZaPovratak,
               "Zahtev")">
            Nazad
        </a>

        @if (korisnikJeAdministrator)
        {
            <a class="dugme-akcije dugme-izmeni"
               href="@Url.Action(
                   "Izmeni",
                   "Zahtev",
                   new
                   {
                       id = Model.ZahtevID
                   })">
                Izmeni prijavu
            </a>
        }

        <button type="button"
                class="dugme-akcije dugme-stampaj"
                onclick="window.print();">
            Štampaj prijavu
        </button>

    </div>

</div>