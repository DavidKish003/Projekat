@model PrezentacionaLogika.ZahtevViewModel

@{
    ViewBag.Title = "Detalji prijave";

    string statusPrijave =
        Convert.ToString(Model.StatusZahteva);

    string klasaStatusa =
        "oznaka-statusa status-nepoznat";

    if (string.Equals(
        statusPrijave,
        "Primljena",
        StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-primljena";
    }
    else if (string.Equals(
        statusPrijave,
        "U razmatranju",
        StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-razmatranje";
    }
    else if (string.Equals(
        statusPrijave,
        "Izabran",
        StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-izabran";
    }
    else if (
        string.Equals(
            statusPrijave,
            "Odbijena",
            StringComparison.OrdinalIgnoreCase)
        ||
        string.Equals(
            statusPrijave,
            "Odbijen",
            StringComparison.OrdinalIgnoreCase))
    {
        klasaStatusa =
            "oznaka-statusa status-odbijena";
    }

    bool korisnikJeAdministrator =
        string.Equals(
            Convert.ToString(Session["Uloga"]),
            "Admin",
            StringComparison.OrdinalIgnoreCase
        )
        ||
        string.Equals(
            Convert.ToString(Session["Uloga"]),
            "Administrator",
            StringComparison.OrdinalIgnoreCase
        );

    string akcijaZaPovratak =
        korisnikJeAdministrator
            ? "Index"
            : "MojePrijave";

    Func<string, string> vrednostIliPrazno =
        delegate (string vrednost)
        {
            if (string.IsNullOrWhiteSpace(vrednost))
            {
                return "";
            }

            return vrednost;
        };

    Func<string, string> vrednostIliNijeUneto =
        delegate (string vrednost)
        {
            if (string.IsNullOrWhiteSpace(vrednost))
            {
                return "Nije uneto";
            }

            return vrednost;
        };

    Func<string, bool> statusJe =
        delegate (string status)
        {
            return string.Equals(
                statusPrijave,
                status,
                StringComparison.OrdinalIgnoreCase
            );
        };

    Func<string, string> oznakaStatusa =
        delegate (string status)
        {
            if (statusJe(status))
            {
                return "☑";
            }

            return "☐";
        };

    Func<string, bool> dokumentJeDostavljen =
        delegate (string nazivDokumenta)
        {
            if (Model.Dokumentacija == null)
            {
                return false;
            }

            foreach (var dokument in Model.Dokumentacija)
            {
                if (string.Equals(
                    Convert.ToString(dokument.NazivDokumenta),
                    nazivDokumenta,
                    StringComparison.OrdinalIgnoreCase))
                {
                    return dokument.Dostavljen;
                }
            }

            return false;
        };

    Func<string, string> oznakaDokumenta =
        delegate (string nazivDokumenta)
        {
            if (dokumentJeDostavljen(nazivDokumenta))
            {
                return "☑";
            }

            return "☐";
        };
}

<style>
    .stranica-detalja {
        max-width: 1050px;
        margin: 35px auto;
        color: #1e293b;
    }

    .zaglavlje-detalja {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 25px;
        margin-bottom: 25px;
        padding: 32px;
        border-radius: 20px;
        background: linear-gradient(135deg, #0f172a, #1e3a5f);
        color: #ffffff;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.16);
    }

    .mali-naslov {
        margin-bottom: 8px;
        color: rgba(255, 255, 255, 0.72);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .ime-kandidata {
        margin: 0 0 10px;
        font-size: 34px;
        font-weight: 700;
    }

    .naziv-konkursa-zaglavlje {
        margin: 0;
        color: rgba(255, 255, 255, 0.82);
        font-size: 17px;
        line-height: 1.5;
    }

    .oznaka-statusa {
        display: inline-block;
        min-width: 120px;
        padding: 10px 16px;
        border-radius: 30px;
        text-align: center;
        font-size: 14px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-primljena {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-razmatranje {
        background: #fef3c7;
        color: #92400e;
    }

    .status-izabran {
        background: #dcfce7;
        color: #166534;
    }

    .status-odbijena {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-nepoznat {
        background: #e2e8f0;
        color: #475569;
    }

    .mreza-podataka {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
        margin-bottom: 25px;
    }

    .kartica-podataka {
        padding: 25px;
        border: 1px solid #e2e8f0;
        border-radius: 17px;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    }

    .naslov-kartice {
        margin: 0 0 20px;
        padding-bottom: 13px;
        border-bottom: 1px solid #e2e8f0;
        color: #0f172a;
        font-size: 19px;
        font-weight: 700;
    }

    .red-podatka {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        padding: 11px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .red-podatka:last-child {
            border-bottom: none;
        }

    .naziv-podatka {
        color: #64748b;
        font-size: 14px;
        font-weight: 600;
    }

    .vrednost-podatka {
        max-width: 65%;
        color: #1e293b;
        text-align: right;
        font-size: 14px;
        font-weight: 700;
        overflow-wrap: anywhere;
    }

    .uslov-ispunjen {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        background: #dcfce7;
        color: #166534;
        font-weight: 700;
    }

    .uslov-nije-ispunjen {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 700;
    }

    .odeljak-sadrzaja {
        margin-bottom: 25px;
        padding: 25px;
        border: 1px solid #e2e8f0;
        border-radius: 17px;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    }

    .tekst-motivacionog-pisma {
        min-height: 90px;
        padding: 18px;
        border-left: 4px solid #0f766e;
        border-radius: 8px;
        background: #f8fafc;
        color: #334155;
        line-height: 1.75;
        white-space: pre-line;
        overflow-wrap: anywhere;
    }

    .prazan-sadrzaj {
        color: #64748b;
        font-style: italic;
    }

    .spisak-dokumenata {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .stavka-dokumenta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 14px 16px;
        border-bottom: 1px solid #e2e8f0;
    }

        .stavka-dokumenta:last-child {
            border-bottom: none;
        }

    .naziv-dokumenta {
        color: #334155;
        font-weight: 600;
    }

    .dokument-dostavljen {
        padding: 6px 11px;
        border-radius: 20px;
        background: #dcfce7;
        color: #166534;
        font-size: 13px;
        font-weight: 700;
    }

    .dokument-nije-dostavljen {
        padding: 6px 11px;
        border-radius: 20px;
        background: #fee2e2;
        color: #991b1b;
        font-size: 13px;
        font-weight: 700;
    }

    .dugmad-akcije {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 25px;
    }

    .dugme-akcije {
        display: inline-block;
        padding: 11px 20px;
        border: none;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .dugme-akcije:hover {
            text-decoration: none;
            transform: translateY(-2px);
        }

    .dugme-nazad {
        background: #e2e8f0;
        color: #334155;
    }

        .dugme-nazad:hover {
            background: #cbd5e1;
            color: #1e293b;
        }

    .dugme-izmeni {
        background: #2563eb;
        color: #ffffff;
    }

        .dugme-izmeni:hover {
            background: #1d4ed8;
            color: #ffffff;
        }

    .dugme-stampaj {
        background: #0f766e;
        color: #ffffff;
    }

        .dugme-stampaj:hover {
            background: #115e59;
            color: #ffffff;
        }

    .dokument-za-stampu {
        display: none;
    }

    @@media (max-width: 768px) {
        .stranica-detalja {
            margin-top: 20px;
        }

        .zaglavlje-detalja {
            flex-direction: column;
            padding: 25px;
        }

        .ime-kandidata {
            font-size: 28px;
        }

        .mreza-podataka {
            grid-template-columns: 1fr;
        }

        .red-podatka {
            flex-direction: column;
            gap: 5px;
        }

        .vrednost-podatka {
            max-width: 100%;
            text-align: left;
        }

        .stavka-dokumenta {
            align-items: flex-start;
            flex-direction: column;
            gap: 8px;
        }

        .dugmad-akcije {
            flex-direction: column;
        }

            .dugmad-akcije .dugme-akcije {
                width: 100%;
                text-align: center;
                box-sizing: border-box;
            }
    }

    @@page {
        size: A4 portrait;
        margin: 10mm;
    }

    @@media print {
        html,
        body {
            width: 210mm;
            min-height: 297mm;
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
            color: #000000 !important;
            font-family: "Times New Roman", Times, serif !important;
            font-size: 10pt !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        nav,
        footer,
        header,
        .navbar,
        .normalni-prikaz,
        .dugmad-akcije {
            display: none !important;
        }

        .container,
        .body-content {
            width: 100% !important;
            max-width: none !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .dokument-za-stampu {
            display: block !important;
            width: 190mm !important;
            margin: 0 auto !important;
            padding: 0 !important;
            background: #ffffff !important;
            color: #000000 !important;
            font-family: "Times New Roman", Times, serif !important;
            font-size: 9.5pt !important;
            line-height: 1.15 !important;
        }

        .stampano-naslov {
            margin: 0 0 2mm 0 !important;
            padding: 0 !important;
            text-align: center !important;
            font-size: 14pt !important;
            font-weight: bold !important;
            text-transform: uppercase !important;
        }

        .stampano-sekcija-naslov {
            margin: 1mm 0 0 0 !important;
            padding: 0 !important;
            font-size: 10pt !important;
            font-weight: bold !important;
            text-transform: uppercase !important;
        }

        .stampano-tabela {
            width: 100% !important;
            border-collapse: collapse !important;
            table-layout: fixed !important;
            margin: 0 !important;
            padding: 0 !important;
        }

            .stampano-tabela td,
            .stampano-tabela th {
                border: 1px solid #000000 !important;
                padding: 2mm 1.5mm !important;
                vertical-align: middle !important;
                color: #000000 !important;
                background: #ffffff !important;
                font-size: 9pt !important;
                font-weight: normal !important;
                line-height: 1.1 !important;
                overflow-wrap: anywhere !important;
            }

        .stampano-labela {
            width: 38mm !important;
            font-weight: bold !important;
            white-space: nowrap !important;
        }

        .stampano-labela-sira {
            width: 50mm !important;
            font-weight: bold !important;
            white-space: nowrap !important;
        }

        .stampano-vrednost {
            font-weight: normal !important;
        }

        .stampano-polje-visoko {
            height: 20mm !important;
            vertical-align: top !important;
        }

        .stampano-checkbox-cell {
            width: 10mm !important;
            text-align: center !important;
            font-size: 12pt !important;
            padding: 1mm !important;
        }

        .stampano-checkbox-red {
            display: inline-block !important;
            margin-right: 4mm !important;
            white-space: nowrap !important;
            font-size: 9pt !important;
        }

        .stampano-napomena {
            height: 12mm !important;
            vertical-align: top !important;
        }

        .stampano-potpisi {
            width: 100% !important;
            margin-top: 7mm !important;
            border-collapse: collapse !important;
            table-layout: fixed !important;
        }

            .stampano-potpisi td {
                border: none !important;
                text-align: center !important;
                vertical-align: top !important;
                font-size: 9pt !important;
                padding: 0 12mm !important;
            }

        .linija-potpisa {
            display: block !important;
            width: 55mm !important;
            margin: 6mm auto 1mm auto !important;
            border-top: 1px solid #000000 !important;
            height: 1px !important;
        }

        .datum-potpisa {
            display: block !important;
            margin-top: 3mm !important;
            text-align: center !important;
        }

        .datum-linija {
            display: inline-block !important;
            width: 38mm !important;
            border-bottom: 1px solid #000000 !important;
            height: 3mm !important;
            vertical-align: bottom !important;
        }

        a[href]::after {
            content: none !important;
        }
    }
</style>

<div class="normalni-prikaz">

    <div class="stranica-detalja">

        <div class="zaglavlje-detalja">

            <div>

                <div class="mali-naslov">
                    Detalji prijave kandidata
                </div>

                <h1 class="ime-kandidata">
                    @Model.ImePrezime
                </h1>

                <p class="naziv-konkursa-zaglavlje">
                    Konkurs: @Model.NazivKonkursa
                </p>

            </div>

            <span class="@klasaStatusa">
                @statusPrijave
            </span>

        </div>

        <div class="mreza-podataka">

            <div class="kartica-podataka">

                <h2 class="naslov-kartice">
                    Podaci o kandidatu
                </h2>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Ime i prezime
                    </span>

                    <span class="vrednost-podatka">
                        @Model.ImePrezime
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        E-mail
                    </span>

                    <span class="vrednost-podatka">
                        @Model.Email
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Telefon
                    </span>

                    <span class="vrednost-podatka">
                        @Model.KontaktTelefon
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Poslednja završena škola
                    </span>

                    <span class="vrednost-podatka">
                        @vrednostIliNijeUneto(Model.PoslednjaSkola)
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Mesto škole
                    </span>

                    <span class="vrednost-podatka">
                        @vrednostIliNijeUneto(Model.MestoSkole)
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Stečeno zanimanje
                    </span>

                    <span class="vrednost-podatka">
                        @vrednostIliNijeUneto(Model.Zanimanje)
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Stepen obrazovanja
                    </span>

                    <span class="vrednost-podatka">
                        @vrednostIliNijeUneto(Model.StepenObrazovanja)
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Godine iskustva
                    </span>

                    <span class="vrednost-podatka">
                        @Model.GodineIskustva
                    </span>
                </div>

            </div>

            <div class="kartica-podataka">

                <h2 class="naslov-kartice">
                    Podaci o prijavi
                </h2>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Naziv konkursa
                    </span>

                    <span class="vrednost-podatka">
                        @vrednostIliNijeUneto(Model.NazivKonkursa)
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Radno mesto
                    </span>

                    <span class="vrednost-podatka">
                        @vrednostIliNijeUneto(Model.RadnoMesto)
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Datum podnošenja
                    </span>

                    <span class="vrednost-podatka">
                        @String.Format(
                                 "{0:dd.MM.yyyy}",
                                 Model.DatumPodnosenja
                             )
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Rok konkursa
                    </span>

                    <span class="vrednost-podatka">
                        @String.Format(
                                 "{0:dd.MM.yyyy}",
                                 Model.RokKonkursa
                             )
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Status prijave
                    </span>

                    <span class="vrednost-podatka">
                        @statusPrijave
                    </span>
                </div>

                <div class="red-podatka">
                    <span class="naziv-podatka">
                        Ispunjava osnovne uslove
                    </span>

                    <span class="vrednost-podatka">
                        @if (Model.IspunjavaOsnovneUslove)
                        {
                            <span class="uslov-ispunjen">
                                Da
                            </span>
                        }
                        else
                        {
                            <span class="uslov-nije-ispunjen">
                                Ne
                            </span>
                        }
                    </span>
                </div>

            </div>

        </div>

        <div class="odeljak-sadrzaja">

            <h2 class="naslov-kartice">
                Motivaciono pismo
            </h2>

            <div class="tekst-motivacionog-pisma">
                @if (string.IsNullOrWhiteSpace(Model.MotivacionoPismo))
                {
                    <span class="prazan-sadrzaj">
                        Nije uneto motivaciono pismo.
                    </span>
                }
                else
                {
                    @Model.MotivacionoPismo
                }
            </div>

        </div>

        <div class="odeljak-sadrzaja">

            <h2 class="naslov-kartice">
                Dokumentacija
            </h2>

            @if (Model.Dokumentacija != null &&
                 Model.Dokumentacija.Count > 0)
            {
                <ul class="spisak-dokumenata">

                    @foreach (var dokument in Model.Dokumentacija)
                    {
                        <li class="stavka-dokumenta">

                            <span class="naziv-dokumenta">
                                @dokument.NazivDokumenta
                            </span>

                            @if (dokument.Dostavljen)
                            {
                                <span class="dokument-dostavljen">
                                    Dostavljen
                                </span>
                            }
                            else
                            {
                                <span class="dokument-nije-dostavljen">
                                    Nije dostavljen
                                </span>
                            }

                        </li>
                    }

                </ul>
            }
            else
            {
                <p class="prazan-sadrzaj">
                    Nema podataka o dokumentaciji.
                </p>
            }

        </div>

        <div class="dugmad-akcije">

            <a class="dugme-akcije dugme-nazad"
               href="@Url.Action(
                   akcijaZaPovratak,
                   "Zahtev")">
                Nazad
            </a>

            @if (korisnikJeAdministrator)
            {
                <a class="dugme-akcije dugme-izmeni"
                   href="@Url.Action(
                       "Izmeni",
                       "Zahtev",
                       new
                       {
                           id = Model.ZahtevID
                       })">
                    Izmeni prijavu
                </a>
            }

            <button type="button"
                    class="dugme-akcije dugme-stampaj"
                    onclick="window.print();">
                Štampaj prijavu
            </button>

        </div>

    </div>

</div>

<div class="dokument-za-stampu">

    <h1 class="stampano-naslov">
        Prijava kandidata na konkurs za posao
    </h1>

    <div class="stampano-sekcija-naslov">
        1. Podaci o kandidatu
    </div>

    <table class="stampano-tabela">

        <tr>
            <td class="stampano-labela">
                Ime i prezime:
            </td>

            <td colspan="3" class="stampano-vrednost">
                @vrednostIliPrazno(Model.ImePrezime)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela">
                Kontakt telefon:
            </td>

            <td class="stampano-vrednost">
                @vrednostIliPrazno(Model.KontaktTelefon)
            </td>

            <td class="stampano-labela">
                E-mail:
            </td>

            <td class="stampano-vrednost">
                @vrednostIliPrazno(Model.Email)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela">
                Poslednja završena škola:
            </td>

            <td colspan="3" class="stampano-vrednost">
                @vrednostIliPrazno(Model.PoslednjaSkola)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela">
                Mesto škole:
            </td>

            <td class="stampano-vrednost">
                @vrednostIliPrazno(Model.MestoSkole)
            </td>

            <td class="stampano-labela">
                Stepen obrazovanja:
            </td>

            <td class="stampano-vrednost">
                @vrednostIliPrazno(Model.StepenObrazovanja)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela">
                Stečeno zanimanje:
            </td>

            <td colspan="3" class="stampano-vrednost">
                @vrednostIliPrazno(Model.Zanimanje)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela">
                Godine iskustva:
            </td>

            <td colspan="3" class="stampano-vrednost">
                @Model.GodineIskustva
            </td>
        </tr>

    </table>

    <div class="stampano-sekcija-naslov">
        2. Podaci o konkursu i prijavi
    </div>

    <table class="stampano-tabela">

        <tr>
            <td class="stampano-labela-sira">
                Naziv konkursa:
            </td>

            <td class="stampano-vrednost">
                @vrednostIliPrazno(Model.NazivKonkursa)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela-sira">
                Radno mesto:
            </td>

            <td class="stampano-vrednost">
                @vrednostIliPrazno(Model.RadnoMesto)
            </td>
        </tr>

        <tr>
            <td class="stampano-labela-sira">
                Datum podnošenja prijave:
            </td>

            <td class="stampano-vrednost">
                @String.Format(
                         "{0:dd.MM.yyyy}",
                         Model.DatumPodnosenja
                     )
            </td>
        </tr>

        <tr>
            <td class="stampano-labela-sira">
                Rok konkursa:
            </td>

            <td class="stampano-vrednost">
                @String.Format(
                         "{0:dd.MM.yyyy}",
                         Model.RokKonkursa
                     )
            </td>
        </tr>

        <tr>
            <td class="stampano-labela-sira stampano-polje-visoko">
                Motivaciono pismo:
            </td>

            <td class="stampano-vrednost stampano-polje-visoko">
                @vrednostIliPrazno(Model.MotivacionoPismo)
            </td>
        </tr>

    </table>

    <div class="stampano-sekcija-naslov">
        3. Dokumentacija
    </div>

    <table class="stampano-tabela">

        <tr>
            <td>
                Biografija (CV)
            </td>

            <td class="stampano-checkbox-cell">
                @oznakaDokumenta("Biografija (CV)")
            </td>
        </tr>

        <tr>
            <td>
                Motivaciono pismo
            </td>

            <td class="stampano-checkbox-cell">
                @oznakaDokumenta("Motivaciono pismo")
            </td>
        </tr>

        <tr>
            <td>
                Diploma ili potvrda o obrazovanju
            </td>

            <td class="stampano-checkbox-cell">
                @oznakaDokumenta("Diploma ili potvrda o obrazovanju")
            </td>
        </tr>

        <tr>
            <td>
                Preporuka prethodnog poslodavca
            </td>

            <td class="stampano-checkbox-cell">
                @oznakaDokumenta("Preporuka prethodnog poslodavca")
            </td>
        </tr>

    </table>

    <div class="stampano-sekcija-naslov">
        4. Status prijave
    </div>

    <table class="stampano-tabela">

        <tr>
            <td class="stampano-labela">
                Status prijave:
            </td>

            <td>
                <span class="stampano-checkbox-red">
                    @oznakaStatusa("Primljena") Primljena
                </span>

                <span class="stampano-checkbox-red">
                    @oznakaStatusa("U razmatranju") U razmatranju
                </span>

                <span class="stampano-checkbox-red">
                    @oznakaStatusa("Odbijena") Odbijena
                </span>

                <span class="stampano-checkbox-red">
                    @oznakaStatusa("Izabran") Izabrana
                </span>
            </td>
        </tr>

        <tr>
            <td class="stampano-labela stampano-napomena">
                Napomena:
            </td>

            <td class="stampano-napomena">
                Ispunjava osnovne uslove:
                @if (Model.IspunjavaOsnovneUslove)
                {
                    <span>Da</span>
                }
                else
                {
                    <span>Ne</span>
                }
            </td>
        </tr>

    </table>

    <table class="stampano-potpisi">

        <tr>
            <td>
                <strong>Potpis kandidata</strong>

                <span class="linija-potpisa"></span>

                <span class="datum-potpisa">
                    Datum:
                    <span class="datum-linija"></span>
                </span>
            </td>

            <td>
                <strong>Potpis HR službenika</strong>

                <span class="linija-potpisa"></span>

                <span class="datum-potpisa">
                    Datum:
                    <span class="datum-linija"></span>
                </span>
            </td>
        </tr>

    </table>

</div>