        }

        .potpisi-za-stampu {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 25mm;
            margin-top: 18mm;
        }

        .potpis-polje {
            padding-top: 2mm;
            border-top: 1px solid #000000;
            text-align: center;
            font-size: 9.5pt;
        }

        .napomena-za-stampu {
            margin-top: 12mm;
            padding-top: 3mm;
            border-top: 1px solid #aaaaaa;
