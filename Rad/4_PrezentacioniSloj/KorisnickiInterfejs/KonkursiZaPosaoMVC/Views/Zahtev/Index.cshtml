@model System.Data.DataTable

@{
    ViewBag.Title = "Prijave kandidata";


    string trenutnaPretraga =
    Convert.ToString(
    Request.QueryString["pretraga"]
    );

    string trenutniStatus =
        Convert.ToString(
            Request.QueryString["status"]
        );

    string pretragaZaStampu =
        string.IsNullOrWhiteSpace(trenutnaPretraga)
            ? "Nije primenjena"
            : trenutnaPretraga;

    string statusZaStampu =
        string.IsNullOrWhiteSpace(trenutniStatus)
            ? "Svi statusi"
            : trenutniStatus;

    int brojRezultata =
        Model == null
            ? 0
            : Model.Rows.Count;

    string datumIzvestaja =
        DateTime.Now.ToString(
            "dd.MM.yyyy. HH:mm"
        );

    int? izabraniZahtevId =
        ViewBag.IzabraniZahtevId == null
            ? (int?)null
            : Convert.ToInt32(
                ViewBag.IzabraniZahtevId
            );

    System.Data.DataTable detaljiIzabranePrijave =
        ViewBag.DetaljiIzabranePrijave
            as System.Data.DataTable;

    System.Data.DataRow izabranaPrijava = null;

    if (Model != null && izabraniZahtevId.HasValue)
    {
        foreach (System.Data.DataRow redPrijave in Model.Rows)
        {
            if (Convert.ToInt32(redPrijave["ZahtevID"]) ==
                izabraniZahtevId.Value)
            {
                izabranaPrijava = redPrijave;
                break;
            }
        }
    }


}

<style>
    .stranica-prijava {
        max-width: 1250px;
        margin: 35px auto;
        color: #1e293b;
    }

    .zaglavlje-prijava {
        position: relative;
        display: flex;
        align-items: center;
