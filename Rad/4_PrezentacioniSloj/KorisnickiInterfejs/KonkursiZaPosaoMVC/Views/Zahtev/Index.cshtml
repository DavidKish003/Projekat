</style>

<div class="stranica-prijava">


    @if (TempData["Poruka"] != null)
    {
        <div class="poruka-uspeha">
            @TempData["Poruka"]
        </div>
    }

    @if (TempData["Greska"] != null)
    {
        <div class="poruka-greske">
            @TempData["Greska"]
        </div>
    }

    <div class="zaglavlje-prijava">

        <div class="sadrzaj-zaglavlja">

            <span class="mali-naslov-prijava">
                Administracija konkursa
            </span>

            <h1 class="naslov-prijava">
                Prijave kandidata
            </h1>

            <p class="opis-prijava">
                Pregledajte sve podnete prijave, otvorite detalje,
                izmenite podatke i donesite odluku o kandidatima.
            </p>

        </div>

        <a class="dugme-nova-prijava"
           href="@Url.Action("Dodaj", "Zahtev")">
            Nova prijava
        </a>

    </div>

    <div class="okvir-filtera">

        <div class="zaglavlje-filtera">

            <h2 class="naslov-filtera">
                Pretraga i filtriranje
            </h2>

            <p class="opis-filtera">
                Prona&#273;ite prijavu prema kandidatu,
                e-mail adresi, konkursu ili statusu.
            </p>

        </div>

        <form method="get"
              action="@Url.Action("Index", "Zahtev")"
              class="obrazac-filtera">

            <div class="polje-filtera">

                <label class="naziv-filtera"
                       for="pretraga">
                    Pretraga
                </label>

                <input type="text"
                       id="pretraga"
                       name="pretraga"
                       class="kontrola-filtera"
                       value="@trenutnaPretraga"
                       placeholder="Ime, e-mail ili naziv konkursa" />

            </div>

            <div class="polje-filtera">

                <label class="naziv-filtera"
                       for="status">
                    Status prijave
                </label>

                <select id="status"
                        name="status"
                        class="kontrola-filtera">

                    <option value="">
                        Svi statusi
                    </option>

                    @foreach (string vrednostStatusa in new[]
                    {
                    "Primljena",
                    "U razmatranju",
                    "Izabran",
                    "Odbijena"
                })
                    {
                        if (trenutniStatus == vrednostStatusa)
                        {
                            <option value="@vrednostStatusa"
                                    selected="selected">
                                @vrednostStatusa
                            </option>
                        }
                        else
                        {
                            <option value="@vrednostStatusa">
                                @vrednostStatusa
                            </option>
                        }
                    }

                </select>

            </div>

            <button type="submit"
                    class="dugme-filtera dugme-pretrazi">
                Pretra&#382;i
            </button>

            <button type="button"
                    class="dugme-filtera dugme-stampaj"
                    onclick="stampajPrijave();">
                &#352;tampaj prikaz
            </button>

            <a class="dugme-filtera dugme-ocisti"
               href="@Url.Action("Index", "Zahtev")">
                O&#269;isti
            </a>

        </form>

    </div>

    <div class="podaci-za-stampu">

        <h1 class="naslov-za-stampu">
            Izve&#353;taj o prijavama kandidata
        </h1>

        <div class="red-podataka-za-stampu">

            <span>
                <strong>Pretraga:</strong>
                @pretragaZaStampu
            </span>

            <span>
                <strong>Status:</strong>
                @statusZaStampu
            </span>

            <span>
                <strong>Broj rezultata:</strong>
                @brojRezultata
            </span>

        </div>

        <div class="red-podataka-za-stampu">

            <span>
                <strong>Datum izve&#353;taja:</strong>
                @datumIzvestaja
            </span>

        </div>

    </div>

    @if (Model == null || Model.Rows.Count == 0)
    {
        <div class="poruka-bez-prijava">

            <h3>
                Nema prona&#273;enih prijava
            </h3>

            <p>
                Trenutno ne postoji nijedna prijava koja odgovara
                izabranim kriterijumima pretrage.
            </p>

        </div>
    }
    else
    {
        <div class="okvir-tabele">

            <table class="tabela-prijava">

                <thead>
                    <tr>
                        <th>Kandidat</th>
                        <th>Konkurs</th>
                        <th>Datum</th>
                        <th>Status</th>

                        <th class="kolona-akcije">
                            Akcije
                        </th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (System.Data.DataRow red in Model.Rows)
                    {
                        var zahtevId =
                            red["ZahtevID"];

                        bool prijavaJeIzabrana =
                            izabraniZahtevId.HasValue
                            &&
                            Convert.ToInt32(zahtevId) ==
                            izabraniZahtevId.Value;

                        string statusPrijave =
                            Convert.ToString(
                                red["StatusZahteva"]
                            );

                        string klasaStatusa =
                            "oznaka-statusa status-nepoznat";

                        if (string.Equals(
                            statusPrijave,
                            "Primljena",
                            StringComparison.OrdinalIgnoreCase))
                        {
                            klasaStatusa =
                                "oznaka-statusa status-primljena";
                        }
                        else if (string.Equals(
                            statusPrijave,
                            "U razmatranju",
                            StringComparison.OrdinalIgnoreCase))
                        {
                            klasaStatusa =
                                "oznaka-statusa status-razmatranje";
                        }
                        else if (string.Equals(
                            statusPrijave,
                            "Izabran",
                            StringComparison.OrdinalIgnoreCase))
                        {
                            klasaStatusa =
                                "oznaka-statusa status-izabran";
                        }
                        else if (
                            string.Equals(
                                statusPrijave,
                                "Odbijena",
                                StringComparison.OrdinalIgnoreCase)
                            ||
                            string.Equals(
                                statusPrijave,
                                "Odbijen",
                                StringComparison.OrdinalIgnoreCase))
                        {
                            klasaStatusa =
                                "oznaka-statusa status-odbijena";
                        }

                        <tr class="@(prijavaJeIzabrana ? "red-izabran" : string.Empty)">

                            <td>
                                <span class="ime-kandidata">
                                    @red["ImePrezime"]
                                </span>

                                <span class="email-kandidata">
                                    @red["Email"]
                                </span>
                            </td>

                            <td>
                                <span class="naziv-konkursa">
                                    @red["NazivKonkursa"]
                                </span>
                            </td>

                            <td class="datum-podnosenja">
                                @String.Format(
                                              "{0:dd.MM.yyyy}",
                                              Convert.ToDateTime(
                                                  red["DatumPodnosenja"]
                                              )
                                          )
                            </td>

                            <td>
                                <span class="@klasaStatusa">
                                    @statusPrijave
                                </span>
                            </td>

                            <td class="kolona-akcije">

                                <div class="grupa-akcija">

                                    <a class="dugme-akcije dugme-detalji"
                                       href="@(Url.Action(
                                           "Index",
                                           "Zahtev",
                                           new
                                           {
                                               izabraniZahtevId = zahtevId,
                                               pretraga = trenutnaPretraga,
                                               status = trenutniStatus
                                           }) + "#master-detail")">
                                        Dokumentacija
                                    </a>

                                    <a class="dugme-akcije dugme-izmeni"
                                       href="@Url.Action(
                                       "Izmeni",
                                       "Zahtev",
                                       new
                                       {
                                           id = zahtevId
                                       })">
                                        Izmeni
                                    </a>

                                    @using (Html.BeginForm(
                                        "Prihvati",
                                        "Zahtev",
                                        FormMethod.Post,
                                        new
                                        {
                                            @class = "obrazac-akcije"
                                        }))
                                    {
                                        <input type="hidden"
                                               name="id"
                                               value="@zahtevId" />

                                        <button type="submit"
                                                class="dugme-akcije dugme-prihvati"
                                                onclick="return confirm('Da li sigurno želite da izaberete ovog kandidata?');">
                                            Prihvati
                                        </button>
                                    }

                                    @using (Html.BeginForm(
                                        "Odbij",
                                        "Zahtev",
                                        FormMethod.Post,
                                        new
                                        {
                                            @class = "obrazac-akcije"
                                        }))
                                    {
                                        <input type="hidden"
                                               name="id"
                                               value="@zahtevId" />

                                        <button type="submit"
                                                class="dugme-akcije dugme-odbij"
                                                onclick="return confirm('Da li sigurno želite da odbijete ovu prijavu?');">
                                            Odbij
                                        </button>
                                    }

                                    @using (Html.BeginForm(
                                        "Obrisi",
                                        "Zahtev",
                                        FormMethod.Post,
                                        new
                                        {
                                            @class = "obrazac-akcije"
                                        }))
                                    {
                                        <input type="hidden"
                                               name="id"
                                               value="@zahtevId" />

                                        <button type="submit"
                                                class="dugme-akcije dugme-obrisi"
                                                onclick="return confirm('Da li sigurno želite trajno da obrišete ovu prijavu? Ova radnja se ne može poništiti.');">
                                            Obri&#353;i
                                        </button>
                                    }

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        if (izabranaPrijava != null)
        {
            <div class="master-detail-okvir"
                 id="master-detail">

                <div class="master-detail-zaglavlje">
                    <div>
                        <span class="master-detail-oznaka">
                            Detail zapis izabranog mastera
                        </span>

                        <h2 class="master-detail-naslov">
                            Dokumentacija prijave #@izabraniZahtevId
                        </h2>

                        <p class="master-detail-opis">
                            Prikazana dokumentacija pripada trenutno izabranoj prijavi kandidata.
                        </p>
                    </div>

                    <a class="dugme-akcije dugme-detalji"
                       href="@Url.Action(
                           "Detalji",
                           "Zahtev",
                           new
                           {
                               id = izabraniZahtevId
                           })">
                        Otvori sve detalje
                    </a>
                </div>

                <div class="master-podaci">
                    <div class="master-podatak">
                        <span class="master-podatak-naziv">Kandidat</span>
                        <span class="master-podatak-vrednost">
                            @izabranaPrijava["ImePrezime"]
                        </span>
                    </div>

                    <div class="master-podatak">
                        <span class="master-podatak-naziv">Konkurs</span>
                        <span class="master-podatak-vrednost">
                            @izabranaPrijava["NazivKonkursa"]
                        </span>
                    </div>

                    <div class="master-podatak">
                        <span class="master-podatak-naziv">Radno mesto</span>
                        <span class="master-podatak-vrednost">
                            @izabranaPrijava["RadnoMesto"]
                        </span>
                    </div>

                    <div class="master-podatak">
                        <span class="master-podatak-naziv">Status prijave</span>
                        <span class="master-podatak-vrednost">
                            @izabranaPrijava["StatusZahteva"]
                        </span>
                    </div>
                </div>

                <div class="detail-sadrzaj">
                    <h3 class="detail-naslov">
                        Dokumentacija kandidata
                    </h3>

                    @if (detaljiIzabranePrijave == null ||
                         detaljiIzabranePrijave.Rows.Count == 0)
                    {
                        <div class="detail-prazno">
                            Za izabranu prijavu nema evidentirane dokumentacije.
                        </div>
                    }
                    else
                    {
                        <table class="detail-tabela">
                            <thead>
                                <tr>
                                    <th>Dokument</th>
                                    <th>Obavezan</th>
                                    <th>Dostavljen</th>
                                    <th>Napomena</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (System.Data.DataRow detalj in
                                    detaljiIzabranePrijave.Rows)
                                {
                                    bool obavezan =
                                        detalj["Obavezan"] != DBNull.Value
                                        &&
                                        Convert.ToBoolean(
                                            detalj["Obavezan"]
                                        );

                                    bool dostavljen =
                                        detalj["Dostavljen"] != DBNull.Value
                                        &&
                                        Convert.ToBoolean(
                                            detalj["Dostavljen"]
                                        );

                                    string napomena =
                                        detalj["Napomena"] == DBNull.Value
                                            ? string.Empty
                                            : Convert.ToString(
                                                detalj["Napomena"]
                                            );

                                    <tr>
                                        <td>
                                            <strong>
                                                @detalj["NazivDokumenta"]
                                            </strong>
                                        </td>

                                        <td>
                                            @(obavezan ? "Da" : "Ne")
                                        </td>

                                        <td>
                                            <span class="detail-status @(dostavljen ? "detail-dostavljen" : "detail-nedostaje")">
                                                @(dostavljen ? "Dostavljen" : "Nije dostavljen")
                                            </span>
                                        </td>

                                        <td>
                                            @(string.IsNullOrWhiteSpace(napomena)
                                                ? "—"
                                                : napomena)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    }


</div>

<script>function stampajPrijave() {
        var prethodniNaslov =
            document.title;

        document.title =
            "Prijave kandidata";

        window.print();

        window.setTimeout(
            function () {
                document.title =
                    prethodniNaslov;
            },
            500
        );
    }</script>
