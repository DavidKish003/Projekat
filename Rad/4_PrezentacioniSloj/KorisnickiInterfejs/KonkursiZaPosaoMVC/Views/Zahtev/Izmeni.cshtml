@model KlasePodataka.ZahtevZaRegistracijuKlasa

@{
    ViewBag.Title = "Izmena prijave";

    var zanimanja =
        ViewBag.Zanimanja
            as System.Collections.Generic.IEnumerable<string>
        ?? new string[0];

    var radnaMesta =
        ViewBag.RadnaMesta
            as System.Collections.Generic.IEnumerable<string>
        ?? new string[0];

    string[] stepeniObrazovanja =
    {
        "Srednja škola",
        "Viša škola",
        "Visoko obrazovanje",
        "Master"
    };

    var izabranaDokumenta =
        ViewBag.IzabranaDokumenta
            as System.Collections.Generic.IEnumerable<int>
        ?? new int[0];

    var skupIzabranihDokumenata =
        new System.Collections.Generic.HashSet<int>(
            izabranaDokumenta
        );

    bool cvDostavljen =
        skupIzabranihDokumenata.Contains(1);

    bool motivacionoPismoDostavljeno =
        skupIzabranihDokumenata.Contains(2);

    bool diplomaDostavljena =
        skupIzabranihDokumenata.Contains(3);

    bool preporukaDostavljena =
        skupIzabranihDokumenata.Contains(4);
}

<style>
    .stranica-izmene {
        max-width: 1050px;
        margin: 35px auto;
        color: #1e293b;
    }

    .zaglavlje-izmene {
        position: relative;
        overflow: hidden;
        margin-bottom: 26px;
        padding: 38px;
        border-radius: 22px;
        background: linear-gradient( 135deg, #172554 0%, #1e3a8a 60%, #0369a1 100% );
        color: #ffffff;
        box-shadow: 0 16px 38px rgba(15, 23, 42, 0.17);
    }

        .zaglavlje-izmene::after {
            content: "";
            position: absolute;
            top: -95px;
            right: -65px;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.07);
        }

    .sadrzaj-zaglavlja {
        position: relative;
        z-index: 1;
    }

    .oznaka-izmene {
        display: inline-block;
        margin-bottom: 12px;
        padding: 6px 13px;
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 30px;
        background: rgba(255, 255, 255, 0.08);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }

    .naslov-izmene {
        margin: 0 0 10px;
        font-size: 36px;
        font-weight: 700;
    }

    .opis-izmene {
        max-width: 720px;
        margin: 0;
        color: rgba(255, 255, 255, 0.82);
        font-size: 16px;
        line-height: 1.7;
    }

    .poruka-validacije,
    .js-poruka-validacije {
        margin-bottom: 24px;
        padding: 16px 20px;
        border: 1px solid #fecaca;
        border-radius: 12px;
        background: #fef2f2;
        color: #991b1b;
    }

        .poruka-validacije:empty {
            display: none;
        }

        .poruka-validacije ul,
        .js-poruka-validacije ul {
            margin: 8px 0 0;
            padding-left: 20px;
        }

    .js-poruka-validacije {
        display: none;
    }

        .js-poruka-validacije.prikazana {
            display: block;
        }

    .obrazac-izmene {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .odeljak-izmene {
        padding: 28px;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 9px 28px rgba(15, 23, 42, 0.06);
    }

    .zaglavlje-odeljka {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 17px;
        border-bottom: 1px solid #e2e8f0;
    }

    .broj-odeljka {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 42px;
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #dbeafe;
        color: #1d4ed8;
        font-size: 17px;
        font-weight: 700;
    }

    .naslov-odeljka {
        margin: 0 0 4px;
        color: #0f172a;
        font-size: 20px;
        font-weight: 700;
    }

    .opis-odeljka {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .mreza-polja {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
    }

    .polje-izmene {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .polje-puna-sirina {
        grid-column: 1 / -1;
    }

    .naziv-polja {
        color: #334155;
        font-size: 14px;
        font-weight: 700;
    }

    .oznaka-obaveznog-polja {
        margin-left: 4px;
        color: #dc2626;
    }

    .kontrola-polja {
        width: 100%;
        min-height: 45px;
        padding: 11px 13px;
        border: 1px solid #cbd5e1;
        border-radius: 9px;
        background: #ffffff;
        color: #1e293b;
        font-size: 15px;
        outline: none;
        box-sizing: border-box;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

        .kontrola-polja:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

        .kontrola-polja.polje-neispravno {
            border-color: #dc2626 !important;
            background: #fff7f7;
            box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
        }

        .kontrola-polja.polje-ispravno {
            border-color: #16a34a;
            background: #f7fff9;
        }

    .field-validation-error,
    .text-danger {
        color: #dc2626;
        font-size: 12px;
        font-weight: 600;
    }

    .kombinovano-polje {
        position: relative;
        display: flex;
        width: 100%;
    }

    .kombinovani-unos {
        flex: 1;
        min-width: 0;
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }

    .dugme-padajuce-liste {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 48px;
        min-height: 45px;
        border: 1px solid #cbd5e1;
        border-left: none;
        border-radius: 0 9px 9px 0;
        background: #f8fafc;
        color: #475569;
        font-size: 16px;
        cursor: pointer;
    }

        .dugme-padajuce-liste:hover {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .dugme-padajuce-liste:focus {
            outline: none;
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

    .padajuca-lista-predloga {
        position: absolute;
        z-index: 1000;
        top: calc(100% + 6px);
        right: 0;
        left: 0;
        display: none;
        max-height: 240px;
        overflow-y: auto;
        padding: 6px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #ffffff;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.15);
    }

        .padajuca-lista-predloga.prikazana {
            display: block;
        }

    .stavka-predloga {
        display: block;
        width: 100%;
        padding: 10px 12px;
        border: none;
        border-radius: 7px;
        background: transparent;
        color: #334155;
        font-size: 14px;
        text-align: left;
        cursor: pointer;
    }

        .stavka-predloga:hover,
        .stavka-predloga:focus {
            background: #dbeafe;
            color: #1d4ed8;
            outline: none;
        }

        .stavka-predloga[hidden] {
            display: none;
        }

    .poruka-bez-predloga {
        display: none;
        margin: 0;
        padding: 10px 12px;
        color: #64748b;
        font-size: 13px;
    }

    .tekstualno-polje {
        min-height: 150px;
        resize: vertical;
        line-height: 1.6;
    }

    .pomocni-tekst {
        margin: 0;
        color: #64748b;
        font-size: 12px;
        line-height: 1.5;
    }

    .mreza-dokumenata {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 15px;
    }

    .stavka-dokumenta {
        display: flex;
        align-items: flex-start;
        gap: 13px;
        padding: 17px;
        border: 1px solid #e2e8f0;
        border-radius: 13px;
        background: #f8fafc;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .stavka-dokumenta:hover {
            border-color: #93c5fd;
            background: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 7px 18px rgba(15, 23, 42, 0.06);
        }

    .izbor-dokumenta {
        flex: 0 0 auto;
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: #2563eb;
        cursor: pointer;
    }

    .podaci-dokumenta {
        display: flex;
        flex: 1;
        flex-direction: column;
        gap: 5px;
    }

    .naziv-dokumenta {
        color: #1e293b;
        font-size: 14px;
        font-weight: 700;
    }

    .opis-dokumenta {
        color: #64748b;
        font-size: 12px;
        line-height: 1.5;
    }

    .oznaka-obavezno {
        display: inline-block;
        align-self: flex-start;
        padding: 4px 8px;
        border-radius: 20px;
        background: #fee2e2;
        color: #991b1b;
        font-size: 11px;
        font-weight: 700;
    }

    .oznaka-opciono {
        display: inline-block;
        align-self: flex-start;
        padding: 4px 8px;
        border-radius: 20px;
        background: #e2e8f0;
        color: #475569;
        font-size: 11px;
        font-weight: 700;
    }

    .napomena-izmene {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-top: 20px;
        padding: 16px;
        border: 1px solid #fde68a;
        border-radius: 12px;
        background: #fffbeb;
        color: #92400e;
    }

    .oznaka-napomene {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 28px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #d97706;
        color: #ffffff;
        font-size: 15px;
        font-weight: 700;
    }

    .tekst-napomene {
        margin: 0;
        font-size: 13px;
        line-height: 1.6;
    }

    .dugmad-izmene {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        padding: 22px 28px;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .dugme-izmene {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 10px 21px;
        border: none;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .dugme-izmene:hover {
            text-decoration: none;
            transform: translateY(-2px);
        }

    .dugme-sacuvaj {
        background: #2563eb;
        color: #ffffff;
        box-shadow: 0 6px 15px rgba(37, 99, 235, 0.2);
    }

        .dugme-sacuvaj:hover {
            background: #1d4ed8;
            color: #ffffff;
        }

    .dugme-nazad {
        border: 1px solid #cbd5e1;
        background: #ffffff;
        color: #475569;
    }

        .dugme-nazad:hover {
            background: #f1f5f9;
            color: #1e293b;
        }

    @@media (max-width: 768px) {
        .stranica-izmene {
            margin-top: 20px;
        }

        .zaglavlje-izmene {
            padding: 28px 23px;
        }

        .naslov-izmene {
            font-size: 29px;
        }

        .odeljak-izmene {
            padding: 22px;
        }

        .mreza-polja,
        .mreza-dokumenata {
            grid-template-columns: 1fr;
        }

        .polje-puna-sirina {
            grid-column: auto;
        }

        .dugmad-izmene {
            align-items: stretch;
            flex-direction: column-reverse;
            padding: 20px;
        }

        .dugme-izmene {
            width: 100%;
        }
    }
</style>

<div class="stranica-izmene">

    <div class="zaglavlje-izmene">

        <div class="sadrzaj-zaglavlja">

            <span class="oznaka-izmene">
                Administracija prijave
            </span>

            <h1 class="naslov-izmene">
                Izmena prijave kandidata
            </h1>

            <p class="opis-izmene">
                Menjate prijavu kandidata
                <strong>@Model.ImePrezime</strong>
                za konkurs
                <strong>@Model.NazivKonkursa</strong>.
            </p>

        </div>

    </div>

    @Html.ValidationSummary(
            false,
            "",
            new
            {
                @class = "poruka-validacije"
            }
        )

    <div id="jsGreske"
         class="js-poruka-validacije"
         role="alert"
         aria-live="assertive">
    </div>

    @using (Html.BeginForm(
        "Izmeni",
        "Zahtev",
        FormMethod.Post,
        new
        {
            @class = "obrazac-izmene",
            id = "FormaPrijave",
            novalidate = "novalidate",
            data_dozvoli_prosli_rok = "true"
        }))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(
                 m => m.ZahtevID
             )

        @Html.Hidden(
                 "DatumPodnosenja",
                 Model.DatumPodnosenja.ToString("yyyy-MM-dd")
             )

        <div class="odeljak-izmene">

            <div class="zaglavlje-odeljka">

                <div class="broj-odeljka">
                    1
                </div>

                <div>

                    <h2 class="naslov-odeljka">
                        Podaci o kandidatu
                    </h2>

                    <p class="opis-odeljka">
                        Lični, kontakt i obrazovni podaci kandidata.
                    </p>

                </div>

            </div>

            <div class="mreza-polja">

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="ImePrezime">
                        Ime i prezime
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.ImePrezime,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "ImePrezime",
                                 maxlength = "100",
                                 placeholder = "Na primer: Marko Marković"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.ImePrezime,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="Email">
                        E-mail adresa
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.Email,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "Email",
                                 type = "email",
                                 maxlength = "100",
                                 placeholder = "marko@email.com"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.Email,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="KontaktTelefon">
                        Kontakt telefon
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.KontaktTelefon,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "KontaktTelefon",
                                 maxlength = "20",
                                 placeholder = "Na primer: 064 123 4567"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.KontaktTelefon,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="PoslednjaSkola">
                        Poslednja završena škola
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.PoslednjaSkola,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "PoslednjaSkola",
                                 maxlength = "150",
                                 placeholder = "Naziv poslednje završene škole"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.PoslednjaSkola,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="MestoSkole">
                        Mesto škole
                    </label>

                    @Html.TextBoxFor(
                             m => m.MestoSkole,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "MestoSkole",
                                 maxlength = "100",
                                 placeholder = "Mesto u kojem je škola završena"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.MestoSkole,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="Zanimanje">
                        Stečeno zanimanje
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    <div class="kombinovano-polje">

                        @Html.TextBoxFor(
                                 m => m.Zanimanje,
                                 new
                                 {
                                     @class = "kontrola-polja kombinovani-unos",
                                     id = "Zanimanje",
                                     maxlength = "150",
                                     placeholder = "Unesite ili izaberite zanimanje",
                                     autocomplete = "off"
                                 }
                             )

                        <button type="button"
                                id="DugmeZanimanja"
                                class="dugme-padajuce-liste"
                                aria-label="Prikaži ponuđena zanimanja"
                                aria-expanded="false">
                            ▼
                        </button>

                        <div id="ListaZanimanja"
                             class="padajuca-lista-predloga">

                            @foreach (string zanimanje in zanimanja)
                            {
                                <button type="button"
                                        class="stavka-predloga"
                                        data-vrednost="@zanimanje">
                                    @zanimanje
                                </button>
                            }

                            <p class="poruka-bez-predloga">
                                Nema pronađenih zanimanja.
                            </p>

                        </div>

                    </div>

                    @Html.ValidationMessageFor(
                             m => m.Zanimanje,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                    <p class="pomocni-tekst">
                        Možete ručno uneti zanimanje ili ga izabrati
                        iz evidencije sistema.
                    </p>

                </div>

                <div class="polje-izmene polje-puna-sirina">

                    <label class="naziv-polja"
                           for="StepenObrazovanja">
                        Stepen obrazovanja
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.DropDownListFor(
                             m => m.StepenObrazovanja,
                             new SelectList(
                                 stepeniObrazovanja,
                                 Model.StepenObrazovanja
                             ),
                             "Izaberite stepen obrazovanja",
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "StepenObrazovanja"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.StepenObrazovanja,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

            </div>

        </div>

        <div class="odeljak-izmene">

            <div class="zaglavlje-odeljka">

                <div class="broj-odeljka">
                    2
                </div>

                <div>

                    <h2 class="naslov-odeljka">
                        Podaci o konkursu
                    </h2>

                    <p class="opis-odeljka">
                        Konkurs, radno mesto, iskustvo i važeći rok prijave.
                    </p>

                </div>

            </div>

            <div class="mreza-polja">

                <div class="polje-izmene polje-puna-sirina">

                    <label class="naziv-polja"
                           for="NazivKonkursa">
                        Naziv konkursa
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.NazivKonkursa,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "NazivKonkursa",
                                 maxlength = "150",
                                 placeholder = "Na primer: Konkurs za rad u IT sektoru"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.NazivKonkursa,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

                <div class="polje-izmene polje-puna-sirina">

                    <label class="naziv-polja"
                           for="RadnoMesto">
                        Radno mesto
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    <div class="kombinovano-polje">

                        @Html.TextBoxFor(
                                 m => m.RadnoMesto,
                                 new
                                 {
                                     @class = "kontrola-polja kombinovani-unos",
                                     id = "RadnoMesto",
                                     maxlength = "150",
                                     placeholder = "Unesite ili izaberite radno mesto",
                                     autocomplete = "off"
                                 }
                             )

                        <button type="button"
                                id="DugmeRadnihMesta"
                                class="dugme-padajuce-liste"
                                aria-label="Prikaži ponuđena radna mesta"
                                aria-expanded="false">
                            ▼
                        </button>

                        <div id="ListaRadnihMesta"
                             class="padajuca-lista-predloga">

                            @foreach (string radnoMesto in radnaMesta)
                            {
                                <button type="button"
                                        class="stavka-predloga"
                                        data-vrednost="@radnoMesto">
                                    @radnoMesto
                                </button>
                            }

                            <p class="poruka-bez-predloga">
                                Nema pronađenih radnih mesta.
                            </p>

                        </div>

                    </div>

                    @Html.ValidationMessageFor(
                             m => m.RadnoMesto,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                    <p class="pomocni-tekst">
                        Možete ručno uneti radno mesto ili ga izabrati
                        iz evidencije sistema.
                    </p>

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="GodineIskustva">
                        Godine iskustva
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.GodineIskustva,
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "GodineIskustva",
                                 type = "number",
                                 min = "0",
                                 max = "50",
                                 step = "1"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.GodineIskustva,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                    <p class="pomocni-tekst">
                        Unesite ceo broj od 0 do 50.
                    </p>

                </div>

                <div class="polje-izmene">

                    <label class="naziv-polja"
                           for="RokKonkursa">
                        Rok konkursa
                        <span class="oznaka-obaveznog-polja">*</span>
                    </label>

                    @Html.TextBoxFor(
                             m => m.RokKonkursa,
                             "{0:yyyy-MM-dd}",
                             new
                             {
                                 @class = "kontrola-polja",
                                 id = "RokKonkursa",
                                 type = "date"
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.RokKonkursa,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                    <p class="pomocni-tekst">
                        Kod izmene je dozvoljen i rok koji je već istekao.
                    </p>

                </div>

                <div class="polje-izmene polje-puna-sirina">

                    <label class="naziv-polja"
                           for="MotivacionoPismo">
                        Motivaciono pismo
                    </label>

                    @Html.TextAreaFor(
                             m => m.MotivacionoPismo,
                             new
                             {
                                 @class = "kontrola-polja tekstualno-polje",
                                 id = "MotivacionoPismo",
                                 maxlength = "5000",
                                 placeholder = "Unesite motivaciono pismo kandidata..."
                             }
                         )

                    @Html.ValidationMessageFor(
                             m => m.MotivacionoPismo,
                             "",
                             new
                             {
                                 @class = "text-danger"
                             }
                         )

                </div>

            </div>

        </div>

        <div class="odeljak-izmene">

            <div class="zaglavlje-odeljka">

                <div class="broj-odeljka">
                    3
                </div>

                <div>

                    <h2 class="naslov-odeljka">
                        Dokumentacija
                    </h2>

                    <p class="opis-odeljka">
                        Označite dokumente koji su dostavljeni uz prijavu.
                    </p>

                </div>

            </div>

            <div class="mreza-dokumenata">

                <label class="stavka-dokumenta">

                    <input type="checkbox"
                           id="Dokument1"
                           name="Dokumenta"
                           value="1"
                           class="izbor-dokumenta"
                           @(cvDostavljen ? "checked=\"checked\"" : "") />

                    <span class="podaci-dokumenta">

                        <span class="naziv-dokumenta">
                            Biografija (CV)
                        </span>

                        <span class="opis-dokumenta">
                            Pregled obrazovanja, iskustva i veština.
                        </span>

                        <span class="oznaka-obavezno">
                            Obavezno
                        </span>

                    </span>

                </label>

                <label class="stavka-dokumenta">

                    <input type="checkbox"
                           id="Dokument2"
                           name="Dokumenta"
                           value="2"
                           class="izbor-dokumenta"
                           @(motivacionoPismoDostavljeno ? "checked=\"checked\"" : "") />

                    <span class="podaci-dokumenta">

                        <span class="naziv-dokumenta">
                            Motivaciono pismo
                        </span>

                        <span class="opis-dokumenta">
                            Obrazloženje interesa za radno mesto.
                        </span>

                        <span class="oznaka-opciono">
                            Opciono
                        </span>

                    </span>

                </label>

                <label class="stavka-dokumenta">

                    <input type="checkbox"
                           id="Dokument3"
                           name="Dokumenta"
                           value="3"
                           class="izbor-dokumenta"
                           @(diplomaDostavljena ? "checked=\"checked\"" : "") />

                    <span class="podaci-dokumenta">

                        <span class="naziv-dokumenta">
                            Diploma ili potvrda o obrazovanju
                        </span>

                        <span class="opis-dokumenta">
                            Dokaz o završenom stepenu obrazovanja.
                        </span>

                        <span class="oznaka-obavezno">
                            Obavezno
                        </span>

                    </span>

                </label>

                <label class="stavka-dokumenta">

                    <input type="checkbox"
                           id="Dokument4"
                           name="Dokumenta"
                           value="4"
                           class="izbor-dokumenta"
                           @(preporukaDostavljena ? "checked=\"checked\"" : "") />

                    <span class="podaci-dokumenta">

                        <span class="naziv-dokumenta">
                            Preporuka prethodnog poslodavca
                        </span>

                        <span class="opis-dokumenta">
                            Potvrda prethodnog radnog iskustva.
                        </span>

                        <span class="oznaka-opciono">
                            Opciono
                        </span>

                    </span>

                </label>

            </div>

            <div class="napomena-izmene">

                <div class="oznaka-napomene">
                    !
                </div>

                <p class="tekst-napomene">
                    Sistem će ponovo proveriti rok konkursa i
                    usklađenost stečenog zanimanja sa izabranim
                    radnim mestom.
                </p>

            </div>

        </div>

        <div class="dugmad-izmene">

            <a class="dugme-izmene dugme-nazad"
               href="@Url.Action(
                   "Index",
                   "Zahtev")">
                Odustani
            </a>

            <button type="submit"
                    class="dugme-izmene dugme-sacuvaj">
                Sačuvaj izmene
            </button>

        </div>
    }

</div>

<script src="@Url.Content("~/Scripts/kombinovana-polja.js")"></script>
<script src="@Url.Content("~/Scripts/validacija-prijave.js")"></script>