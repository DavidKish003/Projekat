@{
    ViewBag.Title = "Prijava";
}

<style>
    .prijava-omotac {
        max-width: 500px;
        margin: 60px auto;
    }

    .prijava-kartica {
        overflow: hidden;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 14px 40px rgba(15, 23, 42, 0.1);
    }

    .prijava-zaglavlje {
        padding: 30px;
        background: linear-gradient(135deg, #0f172a, #1e3a5f);
        color: #ffffff;
        text-align: center;
    }

        .prijava-zaglavlje h1 {
            margin: 0 0 8px;
            font-size: 30px;
            font-weight: 700;
        }

        .prijava-zaglavlje p {
            margin: 0;
            color: rgba(255, 255, 255, 0.8);
        }

    .prijava-telo {
        padding: 35px;
    }

    .grupa-polja {
        margin-bottom: 20px;
    }

    .oznaka-polja {
        display: block;
        margin-bottom: 7px;
        color: #334155;
        font-weight: 600;
    }

    .prijava-dugme {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 9px;
        background: #0f766e;
        color: #ffffff;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
    }

        .prijava-dugme:hover {
            background: #115e59;
        }

    .prijava-linkovi {
        margin-top: 22px;
        text-align: center;
        color: #64748b;
    }

        .prijava-linkovi a {
            font-weight: 600;
        }

    .pocetna-link {
        display: block;
        margin-top: 12px;
    }
</style>

<div class="prijava-omotac">

    @if (TempData["Poruka"] != null)
    {
        <div class="alert alert-success">
            @TempData["Poruka"]
        </div>
    }

    <div class="prijava-kartica">

        <div class="prijava-zaglavlje">
            <h1>Prijava na sistem</h1>

            <p>
                Unesite podatke svog korisničkog naloga.
            </p>
        </div>

        <div class="prijava-telo">

            @if (ViewBag.Greska != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Greska
                </div>
            }

            <form method="post"
                  action="@Url.Action("Index", "Login")">

                <div class="grupa-polja">
                    <label class="oznaka-polja"
                           for="korisnickoIme">
                        Korisničko ime
                    </label>

                    <input type="text"
                           id="korisnickoIme"
                           name="korisnickoIme"
                           class="form-control"
                           value="@Request.Form["korisnickoIme"]"
                           placeholder="Unesite korisničko ime"
                           autocomplete="username"
                           required />
                </div>

                <div class="grupa-polja">
                    <label class="oznaka-polja"
                           for="lozinka">
                        Lozinka
                    </label>

                    <input type="password"
                           id="lozinka"
                           name="lozinka"
                           class="form-control"
                           placeholder="Unesite lozinku"
                           autocomplete="current-password"
                           required />
                </div>

                <button type="submit"
                        class="prijava-dugme">
                    Prijavi se
                </button>

            </form>

            <div class="prijava-linkovi">
                Nemate nalog?

                <a href="@Url.Action("Registracija", "Login")">
                    Registrujte se
                </a>

                <a class="pocetna-link"
                   href="@Url.Action("Index", "Home")">
                    Povratak na početnu stranicu
                </a>
            </div>

        </div>
    </div>

</div>