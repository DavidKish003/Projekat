@{
ViewBag.Title = "Prijava";
}

<style>
    .login-wrapper {
        max-width: 500px;
        margin: 60px auto;
    }

    .login-card {
        overflow: hidden;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 14px 40px rgba(15, 23, 42, 0.1);
    }

    .login-header {
        padding: 30px;
        background: linear-gradient(135deg, #0f172a, #1e3a5f);
        color: #ffffff;
        text-align: center;
    }

        .login-header h1 {
            margin: 0 0 8px;
            font-size: 30px;
            font-weight: 700;
        }

        .login-header p {
            margin: 0;
            color: rgba(255, 255, 255, 0.8);
        }

    .login-body {
        padding: 35px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 7px;
        color: #334155;
        font-weight: 600;
    }

    .login-button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 9px;
        background: #0f766e;
        color: #ffffff;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
    }

        .login-button:hover {
            background: #115e59;
        }

    .login-links {
        margin-top: 22px;
        text-align: center;
        color: #64748b;
    }

        .login-links a {
            font-weight: 600;
        }

    .home-link {
        display: block;
        margin-top: 12px;
    }
</style>

<div class="login-wrapper">


    @if (TempData["Poruka"] != null)
{
    <div class="alert alert-success">
        @TempData["Poruka"]
    </div>
}

    <div class="login-card">

        <div class="login-header">
            <h1>Prijava na sistem</h1>

            <p>
                Unesite podatke svog korisni&#269;kog naloga.
            </p>
        </div>

        <div class="login-body">

            @if (ViewBag.Greska != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Greska
            </div>
        }

            <form method="post"
                  action="@Url.Action("Index", "Login")">

                <div class="form-group">
                    <label class="form-label"
                           for="korisnickoIme">
                        Korisni&#269;ko ime
                    </label>

                    <input type="text"
                           id="korisnickoIme"
                           name="korisnickoIme"
                           class="form-control"
                           value="@Request.Form["korisnickoIme"]"
                           placeholder="Unesite korisni&#269;ko ime"
                           autocomplete="username"
                           required />
                </div>

                <div class="form-group">
                    <label class="form-label"
                           for="lozinka">
                        Lozinka
                    </label>

                    <input type="password"
                           id="lozinka"
                           name="lozinka"
                           class="form-control"
                           placeholder="Unesite lozinku"
                           autocomplete="current-password"
                           required />
                </div>

                <button type="submit"
                        class="login-button">
                    Prijavi se
                </button>

            </form>

            <div class="login-links">
                Nemate nalog?

                <a href="@Url.Action("Registracija", "Login")">
                    Registrujte se
                </a>

                <a class="home-link"
                   href="@Url.Action("Index", "Home")">
                    Povratak na po&#269;etnu stranicu
                </a>
            </div>

        </div>
    </div>


</div>
