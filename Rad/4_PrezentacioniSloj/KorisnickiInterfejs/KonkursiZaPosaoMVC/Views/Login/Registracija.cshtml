@{
    ViewBag.Title = "Registracija";
}

<style>
    .registracija-omotac {
        max-width: 520px;
        margin: 45px auto;
    }

    .registracija-kartica {
        padding: 35px;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 12px 35px rgba(15, 23, 42, 0.09);
    }

    .registracija-naslov {
        margin-bottom: 8px;
        font-size: 30px;
        font-weight: 700;
        color: #0f172a;
    }

    .registracija-opis {
        margin-bottom: 28px;
        color: #64748b;
    }

    .oznaka-polja {
        display: block;
        margin-bottom: 7px;
        font-weight: 600;
        color: #334155;
    }

    .grupa-polja {
        margin-bottom: 20px;
    }

    .registracija-dugme {
        width: 100%;
        padding: 11px;
        border: none;
        border-radius: 9px;
        background: #0f766e;
        color: white;
        font-weight: 600;
        cursor: pointer;
    }

        .registracija-dugme:hover {
            background: #115e59;
        }

    .prijava-link {
        margin-top: 22px;
        text-align: center;
    }
</style>

<div class="registracija-omotac">
    <div class="registracija-kartica">

        <h1 class="registracija-naslov">
            Kreiranje naloga
        </h1>

        <p class="registracija-opis">
            Registrujte korisnički nalog kako biste mogli da
            podnesete prijavu na konkurs za posao.
        </p>

        @if (ViewBag.Greska != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Greska
            </div>
        }

        <form method="post"
              action="@Url.Action("Registracija", "Login")">

            <div class="grupa-polja">
                <label class="oznaka-polja"
                       for="korisnickoIme">
                    Korisničko ime
                </label>

                <input type="text"
                       id="korisnickoIme"
                       name="korisnickoIme"
                       class="form-control"
                       value="@Request.Form["korisnickoIme"]"
                       autocomplete="username"
                       required />
            </div>

            <div class="grupa-polja">
                <label class="oznaka-polja"
                       for="lozinka">
                    Lozinka
                </label>

                <input type="password"
                       id="lozinka"
                       name="lozinka"
                       class="form-control"
                       autocomplete="new-password"
                       required />
            </div>

            <div class="grupa-polja">
                <label class="oznaka-polja"
                       for="potvrdaLozinke">
                    Potvrda lozinke
                </label>

                <input type="password"
                       id="potvrdaLozinke"
                       name="potvrdaLozinke"
                       class="form-control"
                       autocomplete="new-password"
                       required />
            </div>

            <button type="submit"
                    class="registracija-dugme">
                Registruj se
            </button>
        </form>

        <div class="prijava-link">
            Već imate nalog?

            <a href="@Url.Action("Index", "Login")">
                Prijavite se
            </a>
        </div>

    </div>
</div>