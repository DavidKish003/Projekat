@{
     ViewBag.Title = "O sistemu";
}

<div class="text-center mb-5">
     <h1>Sistem za prijavu kandidata</h1>
     <p class="lead">
          Aplikacija za podnošenje, pregled, izmenu i obradu zahteva za registraciju putničkih vozila fizičkih lica.
     </p>
</div>

<div class="row">
     <div class="col-md-4">
          <div class="card shadow-sm mb-3">
               <div class="card-header bg-dark text-white">
                    Namena sistema
               </div>
               <div class="card-body">
                    <p>
                         Sistem omogućava evidentiranje zahteva za prijavu kandidata,
                         čuvanje podataka o vlasniku, vozilu i statusu obrade zahteva.
                    </p>
               </div>
          </div>
     </div>

     <div class="col-md-4">
          <div class="card shadow-sm mb-3">
               <div class="card-header bg-dark text-white">
                    Poslovno pravilo
               </div>
               <div class="card-body">
                    <p>
                         Ako je vozilo starije od definisane granice, sistem automatski
                         označava da je potreban tehnički pregled na svakih 6 meseci.
                    </p>
               </div>
          </div>
     </div>

     <div class="col-md-4">
          <div class="card shadow-sm mb-3">
               <div class="card-header bg-dark text-white">
                    Tehnologije
               </div>
               <div class="card-body">
                    <ul>
                         <li>ASP.NET MVC</li>
                         <li>MS SQL Server</li>
                         <li>Stored procedure</li>
                         <li>XML parametrizacija</li>
                         <li>Višeslojna arhitektura</li>
                    </ul>
               </div>
          </div>
     </div>
</div>

<div class="alert alert-info mt-4">
     Sistem je izrađen kao seminarski rad iz predmeta <b>Razvoj višeslojnog softvera</b>.
</div>

<a href="/Zahtev" class="btn btn-primary btn-lg">📋 Pogledaj zahteve</a>