@{
    ViewBag.Title = "Početna";
}

<style>
    .home-page {
        color: #1f2937;
    }

    .hero-section {
        position: relative;
        overflow: hidden;
        padding: 70px 50px;
        border-radius: 24px;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 55%, #0f766e 100%);
        color: white;
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.22);
    }

        .hero-section::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            top: -100px;
            right: -80px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
        }

        .hero-section::after {
            content: "";
            position: absolute;
            width: 180px;
            height: 180px;
            bottom: -80px;
            left: 35%;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-label {
        display: inline-block;
        margin-bottom: 18px;
        padding: 7px 15px;
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 30px;
        background: rgba(255, 255, 255, 0.1);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }

    .hero-title {
        max-width: 720px;
        margin-bottom: 20px;
        font-size: 48px;
        font-weight: 700;
        line-height: 1.12;
    }

    .hero-description {
        max-width: 650px;
        margin-bottom: 32px;
        color: rgba(255, 255, 255, 0.84);
        font-size: 18px;
        line-height: 1.7;
    }

    .hero-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .hero-button {
        display: inline-block;
        padding: 13px 24px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .hero-button:hover {
            text-decoration: none;
            transform: translateY(-2px);
        }

    .hero-button-primary {
        background: white;
        color: #0f172a;
    }

        .hero-button-primary:hover {
            background: #f1f5f9;
            color: #0f172a;
        }

    .hero-button-secondary {
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: rgba(255, 255, 255, 0.08);
        color: white;
    }

        .hero-button-secondary:hover {
            background: rgba(255, 255, 255, 0.16);
            color: white;
        }

    .section-title {
        margin-top: 55px;
        margin-bottom: 10px;
        text-align: center;
        font-size: 30px;
        font-weight: 700;
    }

    .section-description {
        max-width: 650px;
        margin: 0 auto 35px;
        color: #6b7280;
        text-align: center;
        line-height: 1.7;
    }

    .feature-card {
        height: 100%;
        padding: 28px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        background: white;
        box-shadow: 0 8px 25px rgba(15, 23, 42, 0.06);
        transition: 0.2s ease;
    }

        .feature-card:hover {
            border-color: #cbd5e1;
            transform: translateY(-5px);
            box-shadow: 0 14px 32px rgba(15, 23, 42, 0.1);
        }

    .feature-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        margin-bottom: 20px;
        border-radius: 14px;
        background: #ecfdf5;
        color: #047857;
        font-size: 19px;
        font-weight: 700;
    }

    .feature-card h3 {
        margin-bottom: 12px;
        font-size: 20px;
        font-weight: 700;
    }

    .feature-card p {
        margin-bottom: 0;
        color: #6b7280;
        line-height: 1.65;
    }

    .rule-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 30px;
        margin-top: 55px;
        padding: 35px 40px;
        border-radius: 20px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

        .rule-section h2 {
            margin-top: 0;
            margin-bottom: 10px;
            font-size: 25px;
            font-weight: 700;
        }

        .rule-section p {
            max-width: 700px;
            margin-bottom: 0;
            color: #64748b;
            line-height: 1.7;
        }

    .rule-badge {
        min-width: 175px;
        padding: 16px 20px;
        border-radius: 14px;
        background: #ffffff;
        color: #0f766e;
        text-align: center;
        font-weight: 700;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
    }

    .status-section {
        margin-top: 55px;
        padding: 35px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .status-list {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
        margin-top: 24px;
    }

    .status-item {
        padding: 10px 17px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
    }

    .status-primljena {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-razmatranje {
        background: #fef3c7;
        color: #92400e;
    }

    .status-izabran {
        background: #dcfce7;
        color: #166534;
    }

    .status-odbijena {
        background: #fee2e2;
        color: #991b1b;
    }

    @@media (max-width: 768px) {
        .hero-section {
            padding: 45px 25px;
        }

        .hero-title {
            font-size: 35px;
        }

        .rule-section {
            flex-direction: column;
            align-items: flex-start;
            padding: 28px;
        }

        .rule-badge {
            width: 100%;
        }
    }
</style>

<div class="home-page">
    <section class="hero-section">
        <div class="hero-content">

            <span class="hero-label">
                Upravljanje procesom zapošljavanja
            </span>

            <h1 class="hero-title">
                Jednostavniji pregled kandidata i prijava za posao
            </h1>

            <p class="hero-description">
                Evidentirajte prijave kandidata, proverite ispunjenost osnovnih
                uslova konkursa i upravljajte statusima prijava na jednom mestu.
            </p>

            <div class="hero-buttons">

                <a class="hero-button hero-button-primary"
                   href="@Url.Action("Index", "Zahtev")">
                    Pregledaj prijave
                </a>

                <a class="hero-button hero-button-secondary"
                   href="@Url.Action("Dodaj", "Zahtev")">
                    Dodaj novu prijavu
                </a>

            </div>
        </div>
    </section>

    <section>
        <h2 class="section-title">
            Kako sistem funkcioniše
        </h2>

        <p class="section-description">
            Proces obrade prijave podeljen je na jednostavne korake,
            od evidentiranja kandidata do konačne odluke.
        </p>

        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-number">1</div>

                    <h3>Unos kandidata</h3>

                    <p>
                        Unose se lični i kontakt podaci kandidata,
                        obrazovanje, iskustvo i naziv konkursa.
                    </p>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-number">2</div>

                    <h3>Provera dokumentacije</h3>

                    <p>
                        Sistem proverava da li je kandidat dostavio CV
                        i da li konkurs još uvek traje.
                    </p>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-number">3</div>

                    <h3>Odluka o kandidatu</h3>

                    <p>
                        Prijava se može označiti kao primljena,
                        izabrana, odbijena ili se može trajno obrisati.
                    </p>
                </div>
            </div>

        </div>
    </section>

    <section class="rule-section">

        <div>
            <h2>Automatska provera osnovnih uslova</h2>

            <p>
                Kandidat ispunjava osnovne uslove kada konkurs nije istekao,
                CV je dostavljen i kandidat ima potreban broj godina iskustva.
                U suprotnom, prijava dobija status odbijene prijave.
            </p>
        </div>

        <div class="rule-badge">
            Poslovno pravilo
        </div>

    </section>

    <section class="status-section">

        <h2 class="section-title" style="margin-top: 0;">
            Statusi prijave
        </h2>

        <p class="section-description" style="margin-bottom: 0;">
            Svaka prijava prolazi kroz jedan od definisanih statusa.
        </p>

        <div class="status-list">
            <span class="status-item status-primljena">
                Primljena
            </span>

            <span class="status-item status-razmatranje">
                U razmatranju
            </span>

            <span class="status-item status-izabran">
                Izabran
            </span>

            <span class="status-item status-odbijena">
                Odbijena
            </span>
        </div>

    </section>

</div>
