<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>
        @ViewBag.Title - Konkursi za posao
    </title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>

    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container">

            @Html.ActionLink(
                     "Konkursi za posao",
                     "Index",
                     "Home",
                     null,
                     new { @class = "navbar-brand" }
                 )

            <div class="navbar-nav">

                <a class="nav-link"
                   href="@Url.Action("Index", "Zahtev")">
                    Prijave kandidata
                </a>

                <a class="nav-link"
                   href="@Url.Action("Dodaj", "Zahtev")">
                    Nova prijava
                </a>

                <a class="nav-link"
                   href="@Url.Action("About", "Home")">
                    O sistemu
                </a>

            </div>

        </div>
    </nav>

    <div class="container body-content py-4">

        @RenderBody()

        <hr />

        <footer>
            <p>
                &copy; @DateTime.Now.Year -
                Sistem za prijavu kandidata i obradu konkursa
            </p>
        </footer>

    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection(
            "scripts",
            required: false
        )

</body>
</html>