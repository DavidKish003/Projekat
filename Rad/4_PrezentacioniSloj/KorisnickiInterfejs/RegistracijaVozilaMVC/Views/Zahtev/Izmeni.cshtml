@model System.Data.DataTable

@{
    ViewBag.Title = "Izmena prijave";

    var z = Model.Rows[0];

    DateTime rokKonkursa =
        Convert.ToDateTime(z["RokKonkursa"]);

    string rokKonkursaZaInput =
        rokKonkursa.ToString("yyyy-MM-dd");
}

<h2>Izmena prijave kandidata</h2>

@Html.ValidationSummary(false, "", new { @class = "text-danger" })

<form method="post" action="@Url.Action("Izmeni", "Zahtev")">

    @Html.AntiForgeryToken()

    <input type="hidden"
           name="ZahtevID"
           value="@z["ZahtevID"]" />

    <input type="hidden"
           name="DatumPodnosenja"
           value="@Convert.ToDateTime(z["DatumPodnosenja"]).ToString("yyyy-MM-dd HH:mm:ss")" />

    <div class="row">

        <div class="col-md-6 mb-3">
            <label for="ImePrezime">Ime i prezime</label>

            <input type="text"
                   id="ImePrezime"
                   class="form-control"
                   name="ImePrezime"
                   value="@z["ImePrezime"]"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="Email">E-mail</label>

            <input type="email"
                   id="Email"
                   class="form-control"
                   name="Email"
                   value="@z["Email"]"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="KontaktTelefon">Telefon</label>

            <input type="text"
                   id="KontaktTelefon"
                   class="form-control"
                   name="KontaktTelefon"
                   value="@z["KontaktTelefon"]"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="NazivKonkursa">Konkurs</label>

            <input type="text"
                   id="NazivKonkursa"
                   class="form-control"
                   name="NazivKonkursa"
                   value="@z["NazivKonkursa"]"
                   required />
        </div>

        <div class="col-md-4 mb-3">
            <label for="StepenObrazovanja">Obrazovanje</label>

            <select id="StepenObrazovanja"
                    class="form-control"
                    name="StepenObrazovanja">

                <option value="Srednja škola"
                        selected="@(z["StepenObrazovanja"].ToString() == "Srednja škola")">
                    Srednja škola
                </option>

                <option value="Viša škola"
                        selected="@(z["StepenObrazovanja"].ToString() == "Viša škola")">
                    Viša škola
                </option>

                <option value="Visoko obrazovanje"
                        selected="@(z["StepenObrazovanja"].ToString() == "Visoko obrazovanje")">
                    Visoko obrazovanje
                </option>

                <option value="Master"
                        selected="@(z["StepenObrazovanja"].ToString() == "Master")">
                    Master
                </option>

            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label for="GodineIskustva">Godine iskustva</label>

            <input type="number"
                   id="GodineIskustva"
                   min="0"
                   max="50"
                   class="form-control"
                   name="GodineIskustva"
                   value="@z["GodineIskustva"]" />
        </div>

        <div class="col-md-4 mb-3">
            <label for="RokKonkursa">Rok konkursa</label>

            <input type="date"
                   id="RokKonkursa"
                   class="form-control"
                   name="RokKonkursa"
                   value="@rokKonkursaZaInput"
                   required />
        </div>

        <div class="col-12 mb-3">
            <label for="MotivacionoPismo">Motivaciono pismo</label>

            <textarea id="MotivacionoPismo"
                      class="form-control"
                      rows="5"
                      name="MotivacionoPismo">@z["MotivacionoPismo"]</textarea>
        </div>

    </div>

    <div class="card mt-3">
        <div class="card-header">
            Dokumentacija
        </div>

        <div class="card-body">

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="1" />
                Biografija (CV)
            </label>

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="2" />
                Motivaciono pismo
            </label>

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="3" />
                Diploma
            </label>

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="4" />
                Preporuka
            </label>

        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">
        Sačuvaj izmene
    </button>

    <a class="btn btn-secondary mt-3"
       href="@Url.Action("Index", "Zahtev")">
        Nazad
    </a>

</form>