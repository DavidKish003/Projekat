@model KlasePodataka.ZahtevZaRegistracijuKlasa

@{
    ViewBag.Title = "Nova prijava";
}

<h2>Nova prijava kandidata</h2>

@Html.ValidationSummary(false, "", new { @class = "text-danger" })

<form method="post" action="@Url.Action("Dodaj", "Zahtev")">

    @Html.AntiForgeryToken()

    <div class="row">

        <div class="col-md-6 mb-3">
            <label for="ImePrezime">Ime i prezime</label>

            <input type="text"
                   id="ImePrezime"
                   class="form-control"
                   name="ImePrezime"
                   value="@ViewBag.ImePrezime"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="Email">E-mail</label>

            <input type="email"
                   id="Email"
                   class="form-control"
                   name="Email"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="KontaktTelefon">Telefon</label>

            <input type="text"
                   id="KontaktTelefon"
                   class="form-control"
                   name="KontaktTelefon"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="NazivKonkursa">Naziv konkursa</label>

            <input type="text"
                   id="NazivKonkursa"
                   class="form-control"
                   name="NazivKonkursa"
                   required />
        </div>

        <div class="col-md-6 mb-3">
            <label for="StepenObrazovanja">Stepen obrazovanja</label>

            <select id="StepenObrazovanja"
                    class="form-control"
                    name="StepenObrazovanja">

                <option value="Srednja škola">Srednja škola</option>
                <option value="Viša škola">Viša škola</option>
                <option value="Visoko obrazovanje">Visoko obrazovanje</option>
                <option value="Master">Master</option>
            </select>
        </div>

        <div class="col-md-3 mb-3">
            <label for="GodineIskustva">Godine iskustva</label>

            <input type="number"
                   id="GodineIskustva"
                   min="0"
                   max="50"
                   class="form-control"
                   name="GodineIskustva"
                   value="0" />
        </div>

        <div class="col-md-3 mb-3">
            <label for="RokKonkursa">Rok konkursa</label>

            <input type="date"
                   id="RokKonkursa"
                   class="form-control"
                   name="RokKonkursa"
                   required />
        </div>

        <div class="col-12 mb-3">
            <label for="MotivacionoPismo">Motivaciono pismo</label>

            <textarea id="MotivacionoPismo"
                      class="form-control"
                      rows="4"
                      name="MotivacionoPismo"></textarea>
        </div>

    </div>

    <div class="card">
        <div class="card-header">
            Dokumentacija
        </div>

        <div class="card-body">

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="1" />

                Biografija (CV) — obavezno
            </label>

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="2" />

                Motivaciono pismo
            </label>

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="3" />

                Diploma ili potvrda o obrazovanju — obavezno
            </label>

            <label class="d-block">
                <input type="checkbox"
                       name="Dokumenta"
                       value="4" />

                Preporuka prethodnog poslodavca
            </label>

        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">
        Sačuvaj prijavu
    </button>

    <a class="btn btn-secondary mt-3"
       href="@Url.Action("Index", "Zahtev")">
        Nazad
    </a>

</form>