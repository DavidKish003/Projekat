@model PrezentacionaLogika.ZahtevViewModel

@{
    ViewBag.Title = "Detalji prijave";
}

<h2>Detalji prijave</h2>

<div class="card">
    <div class="card-body">

        <h3>@Model.ImePrezime</h3>

        <p>
            <strong>Konkurs:</strong>
            @Model.NazivKonkursa
        </p>

        <p>
            <strong>E-mail:</strong>
            @Model.Email
        </p>

        <p>
            <strong>Telefon:</strong>
            @Model.KontaktTelefon
        </p>

        <p>
            <strong>Obrazovanje:</strong>
            @Model.StepenObrazovanja
        </p>

        <p>
            <strong>Iskustvo:</strong>
            @Model.GodineIskustva god.
        </p>

        <p>
            <strong>Rok konkursa:</strong>
            @String.Format("{0:dd.MM.yyyy}", Model.RokKonkursa)
        </p>

        <p>
            <strong>Datum podnošenja:</strong>
            @String.Format("{0:dd.MM.yyyy}", Model.DatumPodnosenja)
        </p>

        <p>
            <strong>Status:</strong>
            @Model.StatusZahteva
        </p>

        <p>
            <strong>Ispunjava osnovne uslove:</strong>

            @if (Model.IspunjavaOsnovneUslove)
            {
            <span class="text-success">Da</span>
            }
            else
            {
            <span class="text-danger">Ne</span>
            }
        </p>

        <p>
            <strong>Motivaciono pismo:</strong>
        </p>

        <div class="border rounded p-3 mb-3">
            @if (string.IsNullOrWhiteSpace(Model.MotivacionoPismo))
            {
            <em>Nije uneto motivaciono pismo.</em>
            }
            else
            {
            @Model.MotivacionoPismo
            }
        </div>

        <h5>Dokumentacija</h5>

        @if (Model.Dokumentacija != null && Model.Dokumentacija.Count > 0)
        {
        <ul class="list-group">

            @foreach (var dokument in Model.Dokumentacija)
                {
            <li class="list-group-item d-flex justify-content-between">
                <span>@dokument.NazivDokumenta</span>

                @if (dokument.Dostavljen)
                        {
                <span class="text-success">
                    Dostavljen
                </span>
                        }
                        else
                        {
                <span class="text-danger">
                    Nije dostavljen
                </span>
                        }
            </li>
                }

        </ul>
        }
        else
        {
        <p>Nema podataka o dokumentaciji.</p>
        }

    </div>
</div>

<a class="btn btn-secondary mt-3"
   href="@Url.Action("Index", "Zahtev")">
    Nazad
</a>

<a class="btn btn-primary mt-3"
   href="@Url.Action("Izmeni", "Zahtev", new { id = Model.ZahtevID })">
    Izmeni prijavu
</a>